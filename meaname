import sys
from awsglue.utils import getResolvedOptions
from pyspark.context import SparkContext
from awsglue.context import GlueContext
from awsglue.job import Job
from pyspark.sql import functions as F
from pyspark.sql.types import ArrayType, MapType, StructType

sc = SparkContext.getOrCreate()
glueContext = GlueContext(sc)
spark = glueContext.spark_session
job = Job(glueContext)

# ---- Parameters ----
SOURCE_PATH   = "s3://pske-stg-maintenance/projects/ard-iot-data/ps.NA_PENSKE_TRIAL.measurement.../"
OUTPUT_PATH   = "s3://pske-stg-maintenance/projects/ard-iot-data-analysis/measurementConfigurat.../"
VIN_COL       = "metaData_vin"
PARTITION_COL = "metaData_measurementConfigurationName"
FILES_PER_PARTITION = 1

# ---- Read Parquet ----
df = (spark.read
      .option("recursiveFileLookup", "true")
      .parquet(SOURCE_PATH))

# ---- Group by VIN (partition col kept so it survives) ----
group_cols = [VIN_COL, PARTITION_COL]
agg_cols   = [c for c in df.columns if c not in group_cols]
agg_exprs  = [F.first(c, ignorenulls=True).alias(c) for c in agg_cols]
grouped = df.groupBy(*group_cols).agg(*agg_exprs) if agg_exprs else df.select(*group_cols).distinct()

# ---- Make it CSV-safe: turn array/map/struct columns into JSON strings ----
for field in grouped.schema.fields:
    if isinstance(field.dataType, (ArrayType, MapType, StructType)):
        grouped = grouped.withColumn(field.name, F.to_json(F.col(field.name)))

# ---- Write to S3 as CSV, partitioned by measurement configuration name ----
(grouped
    .repartition(FILES_PER_PARTITION, PARTITION_COL)
    .write
    .mode("overwrite")
    .partitionBy(PARTITION_COL)
    .option("header", "true")
    .csv(OUTPUT_PATH))

job.commit()
