import sys
from pyspark.context import SparkContext
from awsglue.context import GlueContext
from awsglue.job import Job
from pyspark.sql.functions import col, input_file_name

sc = SparkContext.getOrCreate()
glueContext = GlueContext(sc)
spark = glueContext.spark_session

# --- Configuration ---
SOURCE_DATE   = "20260520"
SOURCE_PREFIX = (
    "s3://pske-stg-maintenance/projects/ard-iot-data/"
    f"ps.NA_PENSKE_TRIAL.measurements.results/{SOURCE_DATE}/"
)
TARGET_COLUMN = "your_column_name"   # <-- CHANGE THIS
DEST_PREFIX = (
    "s3://pske-stg-maintenance/projects/ard-iot-data/"
    f"extracted-output/{SOURCE_DATE}/{TARGET_COLUMN}/"
)

# --- Read recursively across all timestamp folders, merging schemas ---
df = (
    spark.read
    .option("recursiveFileLookup", "true")
    .option("mergeSchema", "true")
    .parquet(SOURCE_PREFIX)
)
print("Columns available:", df.columns)

# --- Select only the target column ---
if TARGET_COLUMN not in df.columns:
    raise ValueError(f"'{TARGET_COLUMN}' not found. Available: {df.columns}")

result = (
    df.select(
        col(TARGET_COLUMN),
        input_file_name().alias("source_file")   # optional, drop if not needed
    )
    .where(col(TARGET_COLUMN).isNotNull())
)
result.show(20, truncate=False)

# --- Write the single column back to S3 ---
(
    result
    .coalesce(1)                 # one output file; remove for large data
    .write
    .mode("overwrite")
    .parquet(DEST_PREFIX)
)
print(f"Done. Written to: {DEST_PREFIX}")
