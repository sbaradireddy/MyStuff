# %% CELL 1 — Glue session config (notebook only)
%idle_timeout 60
%glue_version 4.0
%worker_type G.1X
%number_of_workers 5


# %% CELL 2 — Imports + Spark/Glue context
import sys
from awsglue.utils import getResolvedOptions
from pyspark.context import SparkContext
from awsglue.context import GlueContext
from awsglue.job import Job
from pyspark.sql import functions as F
from pyspark.sql.types import NumericType, TimestampType, StringType

sc = SparkContext.getOrCreate()
glueContext = GlueContext(sc)
spark = glueContext.spark_session
job = Job(glueContext)


# %% CELL 3 — ⚙️ EDIT THESE TWO PATHS
SRC_PARQUET = "s3://YOUR-BUCKET/path/to/source/parquet/"        # <-- your source
DST_CSV     = "s3://pske-stg-maintenance/projects/ard-iot-data-analysis/data-analysis-vin-vehicleid/"  # <-- output base

# Fixed for your dataset (do not need to change):
TS_COL          = "metaData_start"           # event timestamp to bucket on
GROUP_COLS      = ["metaData_vehicleId", "metaData_vin"]
SENSOR_PREFIXES = ("resultData_",)           # numeric sensor columns to aggregate
WINDOWS = {"15min": "15 minutes", "1hour": "1 hour", "1day": "1 day"}

print("Source:", SRC_PARQUET)
print("Output:", DST_CSV)


# %% CELL 4 — Read Parquet + cast sensor columns to numeric + parse timestamp
df = spark.read.parquet(SRC_PARQUET)
print("Raw rows:", df.count())

# --- cast string sensor columns (resultData_*) to double so they get avg/min/max ---
for c in df.columns:
    if c.startswith(SENSOR_PREFIXES) and isinstance(df.schema[c].dataType, StringType):
        df = df.withColumn(c, F.col(c).cast("double"))

# --- robust timestamp parse: handles real timestamp, epoch ms/s, or string (ISO / epoch-text) ---
dt = df.schema[TS_COL].dataType
ts = F.col(TS_COL)
if isinstance(dt, TimestampType):
    ts_expr = ts
elif isinstance(dt, NumericType):
    ts_expr = F.when(ts > F.lit(1_000_000_000_000), F.timestamp_millis(ts.cast("long"))) \
               .otherwise(F.timestamp_seconds(ts.cast("long")))
else:  # string
    digits = F.regexp_replace(ts, r"\D", "")
    ts_expr = F.coalesce(
        F.to_timestamp(ts),
        F.when(F.length(digits) >= 13, F.timestamp_millis(digits.cast("long"))),
        F.when(F.length(digits).between(10, 12), F.timestamp_seconds(digits.cast("long"))),
    )
df = df.withColumn(TS_COL, ts_expr)

print("Non-null timestamps:", df.filter(F.col(TS_COL).isNotNull()).count())   # must be > 0
df = df.dropna(subset=[TS_COL] + GROUP_COLS)
print("Rows kept:", df.count())                                               # must be > 0


# %% CELL 5 — Classify columns: numeric signals vs descriptive metadata
reserved = set(GROUP_COLS + [TS_COL])
numeric_cols, meta_cols = [], []
for f in df.schema.fields:
    if f.name in reserved:
        continue
    if isinstance(f.dataType, NumericType):
        numeric_cols.append(f.name)     # resultData_Uptime_*, resultData_SupplyVoltage_*
    else:
        meta_cols.append(f.name)        # device ids, config names, etc.

print("Numeric signals aggregated:", numeric_cols)
print("Metadata kept (first value):", meta_cols)


# %% CELL 6 — Aggregation builder + windowing function
def build_aggregations(numeric_cols, meta_cols, ts_col):
    aggs = [
        F.count(F.lit(1)).alias("record_count"),
        F.min(ts_col).alias("first_reading_ts"),
        F.max(ts_col).alias("last_reading_ts"),
    ]
    for c in numeric_cols:
        aggs += [
            F.avg(c).alias(f"{c}_avg"),
            F.min(c).alias(f"{c}_min"),
            F.max(c).alias(f"{c}_max"),
            F.stddev(c).alias(f"{c}_stddev"),
            F.expr(f"min_by(`{c}`, `{ts_col}`)").alias(f"{c}_first"),
            F.expr(f"max_by(`{c}`, `{ts_col}`)").alias(f"{c}_last"),
        ]
    for c in meta_cols:
        aggs.append(F.first(c, ignorenulls=True).alias(c))
    return aggs

def aggregate_window(df, duration, group_cols, ts_col, numeric_cols, meta_cols):
    aggs = build_aggregations(numeric_cols, meta_cols, ts_col)
    res = (
        df.groupBy(*group_cols, F.window(F.col(ts_col), duration).alias("w"))
          .agg(*aggs)
          .withColumn("window_start", F.col("w.start"))
          .withColumn("window_end",   F.col("w.end"))
          .drop("w")
    )
    front = group_cols + ["window_start", "window_end", "record_count",
                          "first_reading_ts", "last_reading_ts"]
    rest = [c for c in res.columns if c not in front]
    return res.select(*front, *rest).orderBy(*group_cols, "window_start")


# %% CELL 7 — Run all three granularities and write CSV to S3
def write_csv(df, base_path, label):
    out = base_path.rstrip("/") + "/" + label + "/"
    df.coalesce(1).write.mode("overwrite").option("header", "true").csv(out)
    print(f"  wrote {label} -> {out}")

for label, duration in WINDOWS.items():
    print(f"Computing {label} ({duration}) aggregation...")
    result = aggregate_window(df, duration, GROUP_COLS, TS_COL, numeric_cols, meta_cols)
    result.show(5, truncate=False)
    write_csv(result, DST_CSV, label)

print("Done. CSVs are under:", DST_CSV)


# %% CELL 8 — Commit (Job runs only; harmless in a notebook)
try:
    job.commit()
except Exception:
    pass
