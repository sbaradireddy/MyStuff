%glue_version 4.0
%worker_type G.2X
%number_of_workers 10
%idle_timeout 60
%%configure
{
  "--conf": "spark.sql.parquet.mergeSchema=false --conf spark.driver.maxResultSize=4g --conf spark.sql.adaptive.enabled=true"
}



from awsglue.context import GlueContext
from pyspark.context import SparkContext
from pyspark.sql import functions as F
from pyspark.sql.window import Window

sc = SparkContext.getOrCreate()
glueContext = GlueContext(sc)
spark = glueContext.spark_session

# ---------------- CONFIG ----------------
SRC      = "s3://pske-stg-maintenance/projects/ard-iot-data-compacted/"
OUT_LONG = "s3://pske-stg-maintenance/analytics/measurement_signal_long/"
OUT_SUM  = "s3://pske-stg-maintenance/analytics/measurement_summary/"
MEAS     = "metadata_measurementconfigurationname"
# ----------------------------------------

df = (spark.read
      .option("mergeSchema", "false")
      .option("recursiveFileLookup", "true")
      .parquet(SRC))

# measurement_name + all the sensor (resultdata_) columns
signal_cols = [c for c in df.columns if c.startswith("resultdata_")]
print("measurement col present:", MEAS in df.columns)
print("signal columns found:", len(signal_cols))

df = df.select(MEAS, *signal_cols).withColumnRenamed(MEAS, "measurement_name")
df.show(5, truncate=True)


# Cast all signal columns to string so stack() has one common type
casted = [F.col(c).cast("string").alias(c) for c in signal_cols]
wide = df.select("measurement_name", *casted)

pairs = ",".join([f"'{c}', `{c}`" for c in signal_cols])
expr  = f"stack({len(signal_cols)}, {pairs}) as (signal_col, signal_value)"

long_df = (wide.select("measurement_name", F.expr(expr))
           .filter(F.col("signal_value").isNotNull())
           # clean resultdata_enginespeed_154 -> enginespeed
           .withColumn("signal_name",
                       F.regexp_replace(
                           F.regexp_replace(F.col("signal_col"), r"^resultdata_", ""),
                           r"_\d+$", "")))

long_df.show(10, truncate=False)




# (A) Long detail: one row per signal value, partitioned by measurement_name
(long_df.write.mode("overwrite")
   .option("header", "true")
   .partitionBy("measurement_name")
   .csv(OUT_LONG))

# (B) Summary for QuickSight: counts/pct/rank per measurement_name
total = df.count()
summary = (df.groupBy("measurement_name")
           .agg(F.count("*").alias("row_count"))
           .withColumn("pct", F.round(F.col("row_count")/total*100, 1))
           .orderBy(F.desc("row_count")))
summary = summary.withColumn(
    "rank", F.row_number().over(Window.orderBy(F.desc("row_count"))))

(summary.coalesce(1).write.mode("overwrite")
   .option("header", "true").csv(OUT_SUM))

summary.show(truncate=False)
print("Long detail ->", OUT_LONG)
print("Summary     ->", OUT_SUM)

